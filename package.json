{
  "name": "@prmission/sdk",
  "version": "2.0.0",
  "description": "TypeScript SDK for the Prmission Protocol — consent-gated data exchange with ERC-8004 trust verification",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "test": "node test/smoke.test.ts",
    "example": "node examples/basic.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    ".env.example",
    "docs",
    "examples"
  ],
  "keywords": [
    "prmission",
    "data",
    "monetization",
    "erc-8004",
    "consent",
    "escrow",
    "base"
  ],
  "license": "Apache-2.0"
}